@{
    ViewData["Title"] = "Chat";
}

<div class="app-shell">
    <!-- Top bar -->
    <header class="topbar">
        <div class="brand">
            <i class="bi bi-robot"></i>
            <div>
                <div class="brand-title">AI SQL Agent</div>
                <div class="brand-sub">Chat with your database</div>
            </div>
        </div>
        <div class="topbar-actions">
            <span id="activeModelBadge" class="active-badge desktop-only" title="Active model"></span>
            <span id="activeSourceBadge" class="active-badge desktop-only" title="Active data source"></span>
            <button id="themeToggle" class="icon-btn desktop-only" title="Toggle theme">
                <i class="bi bi-moon-stars"></i>
            </button>
            <button id="settingsToggle" class="icon-btn" title="Settings / menu">
                <i class="bi bi-gear desktop-only"></i>
                <i class="bi bi-list mobile-only"></i>
            </button>
        </div>
    </header>

    <!-- Main chat -->
    <main class="chat-main">
        <div id="messages" class="messages">
            <div class="empty-state">
                <i class="bi bi-chat-square-dots"></i>
                <h5>Ask anything about your data</h5>
                <p>e.g. “How many students are in each class?” or “Top 5 highest fees.”</p>
            </div>
        </div>

        <form id="askForm" class="composer">
            <button type="button" id="clearBtn" class="icon-btn" title="Clear chat">
                <i class="bi bi-trash3"></i>
            </button>
            <input id="questionInput" class="form-control" autocomplete="off"
                   placeholder="Ask a question in plain English…" />
            <button type="submit" id="sendBtn" class="btn btn-primary">
                <i class="bi bi-send"></i>
            </button>
        </form>
    </main>
</div>

<!-- Settings panel (slide-in) -->
<div id="settingsBackdrop" class="settings-backdrop hidden"></div>
<aside id="settingsPanel" class="settings-panel hidden">
    <div class="settings-header">
        <h5><i class="bi bi-gear"></i> Settings</h5>
        <button id="settingsClose" class="icon-btn"><i class="bi bi-x-lg"></i></button>
    </div>

    <div class="settings-body">
        <div class="side-section">
            <label class="side-label"><i class="bi bi-palette"></i> Theme</label>
            <div class="btn-group w-100" role="group">
                <input type="radio" class="btn-check" name="theme" id="themeDark" value="dark">
                <label class="btn btn-sm btn-outline-secondary" for="themeDark"><i class="bi bi-moon"></i> Dark</label>
                <input type="radio" class="btn-check" name="theme" id="themeLight" value="light">
                <label class="btn btn-sm btn-outline-secondary" for="themeLight"><i class="bi bi-sun"></i> Light</label>
            </div>
        </div>

        <div class="side-section">
            <label class="side-label"><i class="bi bi-hdd-network"></i> Provider</label>
            <select id="providerSelect" class="form-select form-select-sm">
                <option value="0">Ollama (Local)</option>
                <option value="1">Groq (Cloud)</option>
            </select>
        </div>

        <div class="side-section">
            <label class="side-label"><i class="bi bi-cpu"></i> Model</label>
            <select id="modelSelect" class="form-select form-select-sm"></select>
            <div class="side-hint" id="providerHint"></div>
        </div>

        <div class="side-section">
            <label class="side-label"><i class="bi bi-database"></i> Data source</label>
            <select id="dialectSelect" class="form-select form-select-sm mb-2">
                <option value="">Demo database (default)</option>
                <option value="0">PostgreSQL (custom)</option>
                <option value="1">MySQL (custom)</option>
                <option value="2">SQL Server (custom)</option>
            </select>
            <textarea id="connStr" class="form-control form-control-sm"
                      rows="3" placeholder="Connection string (leave empty for demo DB)"
                      disabled></textarea>
            <div class="side-hint">
                <i class="bi bi-shield-lock"></i>
                Queries run read-only. Use a read-only DB user when possible.
            </div>
            <div class="side-hint">
                <i class="bi bi-info-circle"></i>
                Host tip: use <code>localhost</code> when running the app natively;
                use <code>host.docker.internal</code> when the app runs in Docker
                and the DB is on your host.
            </div>
            <button id="refreshSchemaBtn" class="btn btn-sm btn-outline-secondary mt-2">
                <i class="bi bi-arrow-repeat"></i> Refresh schema
            </button>
            <div id="schemaStatus" class="side-hint"></div>
        </div>

        <div id="settingsError" class="settings-error hidden"></div>
    </div>

    <div class="settings-footer">
        <button id="settingsReset" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-counterclockwise"></i> Reset
        </button>
        <button id="settingsCancel" class="btn btn-sm btn-outline-secondary">Cancel</button>
        <button id="settingsSave" class="btn btn-sm btn-primary">
            <i class="bi bi-check2"></i> Save
        </button>
    </div>
</aside>

<!-- Full-page loader / mask (shown while applying settings) -->
<div id="pageMask" class="page-mask hidden">
    <div class="mask-box">
        <div class="spinner-border text-light"></div>
        <div id="maskText" class="mask-text">Applying…</div>
    </div>
</div>

<!-- Show Query modal -->
<div class="modal fade" id="sqlModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-code-square"></i> Generated SQL</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre id="sqlModalBody" class="sql-block"></pre>
            </div>
            <div class="modal-footer">
                <button id="copySqlBtn" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-clipboard"></i> Copy
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
