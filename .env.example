# Copy this file to ".env" and fill in values, then run the full compose stack.
#   cp .env.example .env
#
# The .env file is gitignored, so your key never gets committed.

# Optional: Groq cloud API key (free at https://console.groq.com/keys).
# Leave empty to run with the local Ollama provider only.
GROQ_API_KEY=
